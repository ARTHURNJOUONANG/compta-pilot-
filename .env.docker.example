# Copier vers .env.docker : cp .env.docker.example .env.docker

# Port exposé sur la machine hôte
APP_PORT=3000

# SQLite (chemin dans le volume Docker — ne pas modifier)
DATABASE_URL=file:/data/compta.db
UPLOADS_DIR=/data/uploads

# Sécurité (générer : openssl rand -base64 32)
SESSION_SECRET=remplacer-par-un-secret-long-et-aleatoire

# URL vue par le navigateur
APP_URL=http://localhost:3000

# Emails (optionnel — activer avec : docker compose --profile mail up -d)
EMAIL_FROM=Compta Pilot <noreply@cabinet.local>
# MAILER_DSN=smtp://mailpit:1025

# Mailpit (ports hôte)
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
