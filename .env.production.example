# Copier : cp .env.production.example .env.production
# Ne jamais committer .env.production

# --- Domaine (obligatoire pour HTTPS) ---
# Sous-domaine pointant vers l'IP du serveur (enregistrement A chez OVH, Gandi, Cloudflare…)
DOMAIN=compta.votrecabinet.fr

# URL publique exacte (https obligatoire en prod)
APP_URL=https://compta.votrecabinet.fr

# Secret sessions (générer : openssl rand -base64 32)
SESSION_SECRET=remplacer-par-un-secret-long-et-aleatoire

# Expéditeur des emails
EMAIL_FROM=Compta Pilot <noreply@votrecabinet.fr>

# --- SMTP (obligatoire en production) ---
# Exemple Brevo (gratuit ~300 mails/jour) : https://www.brevo.com
# MAILER_DSN=smtps://VOTRE_LOGIN_SMTP:VOTRE_CLE_SMTP@smtp-relay.brevo.com:465

# Ou variables séparées :
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=votre-login
# SMTP_PASS=votre-cle-smtp

MAILER_DSN=

# Données démo pour la présentation (optionnel, une seule fois après premier démarrage)
# SEED_DEMO=true
