generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  DIRECTOR
  MANAGER
  COLLABORATOR
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_VALIDATION
  DONE
}

enum TaskPriority {
  URGENT
  IMPORTANT
  NORMAL
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_OVERDUE
  VALIDATION_REQUESTED
  TASK_COMPLETED
  OCR_COMPLETED
}

enum DocumentCategory {
  FACTURE
  JUSTIFICATIF
  CONTRAT
  AUTRE
}

enum OcrStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  SKIPPED
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  name               String
  role               Role           @default(COLLABORATOR)
  passwordHash       String
  reliabilityScore   Float          @default(75)
  maxConcurrentTasks Int            @default(8)
  tasks              Task[]         @relation("Assignee")
  notifications      Notification[]
  documents          Document[]     @relation("UploadedBy")
  contractsCreated   Contract[]     @relation("ContractsCreated")
  createdAt          DateTime       @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  taskId    String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  CANCELLED
}

enum ContractTemplateType {
  LETTRE_MISSION
  CONVENTION_HONORAIRES
  ENGAGEMENT_ACOMPTE
  ACCORD_RGPD
}

model Client {
  id        String     @id @default(cuid())
  name      String
  siret     String?
  email     String?
  phone     String?
  notes     String?
  tasks     Task[]
  documents Document[]
  contracts Contract[]
  createdAt DateTime   @default(now())
}

model Contract {
  id               String               @id @default(cuid())
  clientId         String
  client           Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  templateType     ContractTemplateType
  title            String
  status           ContractStatus       @default(DRAFT)
  fieldsJson       String               @default("{}")
  renderedBody     String               @default("")
  cabinetSigner    String?
  clientSigner     String?
  cabinetSignature String?
  clientSignature  String?
  signedAt         DateTime?
  createdById      String?
  createdBy        User?                @relation("ContractsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([clientId, status])
  @@index([status])
}

model Document {
  id           String           @id @default(cuid())
  clientId     String
  client       Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fileName     String
  storedName   String
  mimeType     String
  sizeBytes    Int
  category     DocumentCategory @default(AUTRE)
  label        String?
  uploadedById String?
  uploadedBy   User?            @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  ocrStatus         OcrStatus  @default(PENDING)
  ocrText           String?
  ocrProcessedAt    DateTime?
  extractedAmount   Float?
  extractedDate       DateTime?
  extractedVendor     String?
  extractedInvoiceNo  String?
  extractedSiret      String?
  createdAt    DateTime         @default(now())

  @@index([clientId, category])
  @@index([ocrStatus])
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  category       String
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(NORMAL)
  dueDate        DateTime
  validationStep Int          @default(1)
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assigneeId     String?
  assignee       User?        @relation("Assignee", fields: [assigneeId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
