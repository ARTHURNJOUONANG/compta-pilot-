# Base de données SQLite (fichier local)
DATABASE_URL="file:./dev.db"
# Dossier des documents uploadés (optionnel, défaut : ./uploads)
# UPLOADS_DIR="./uploads"

# Sécurité — obligatoire en production (openssl rand -base64 32)
SESSION_SECRET="changez-moi-en-production-minimum-32-caracteres"

# URL publique de l'application (liens emails)
APP_URL="http://localhost:3000"

# Emails — obligatoire en production
EMAIL_FROM="Compta Pilot <noreply@votre-cabinet.fr>"
MAILER_DSN="smtp://user:pass@smtp.example.com:587"
# ou :
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="user"
# SMTP_PASS="pass"

# Données de démonstration (uniquement développement)
# SEED_DEMO="true"
